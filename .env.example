# Friend local development environment example.
# Copy values into a private local .env file if your tooling loads one.
# Never commit real secrets, production credentials, provider keys, or private certificates.

FRIEND_DB_URL=jdbc:postgresql://localhost:5432/friend
FRIEND_DB_USERNAME=friend
FRIEND_DB_PASSWORD=friend_dev_password

# Local/dev only. Never set true in production.
FRIEND_SECURITY_DEV_ACTOR_ENABLED=true

# Required outside dev/test. Use private secrets management in real environments.
FRIEND_AUDIT_HASH_PEPPER=replace-with-local-development-pepper

# Required outside dev/test for Spring Security JWT resource server.
# Prefer issuer URI when your identity provider supports OIDC discovery.
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://issuer.example.com
# Or configure a JWK Set URI instead of an issuer URI.
# SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=https://issuer.example.com/.well-known/jwks.json
